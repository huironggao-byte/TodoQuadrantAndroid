<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_row_4"
    android:layout_width="match_parent"
    android:layout_height="0dp"
    android:layout_marginTop="5dp"
    android:layout_weight="1"
    android:background="@drawable/widget_row_background"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingStart="8dp"
    android:paddingEnd="8dp"
    android:visibility="gone">

    <TextView
        android:id="@+id/widget_row_check_4"
        android:layout_width="36dp"
        android:layout_height="match_parent"
        android:gravity="center"
        android:text="○"
        android:textColor="#B5493B"
        android:textSize="25sp" />

    <LinearLayout
        android:id="@+id/widget_row_texts_4"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:gravity="center_vertical"
        android:orientation="vertical"
        android:paddingStart="8dp"
        android:paddingEnd="6dp">

        <TextView
            android:id="@+id/widget_row_title_4"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="#202124"
            android:textSize="17sp" />

        <TextView
            android:id="@+id/widget_row_meta_4"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="#6F7479"
            android:textSize="13sp" />
    </LinearLayout>

    <TextView
        android:id="@+id/widget_row_star_4"
        android:layout_width="28dp"
        android:layout_height="match_parent"
        android:gravity="center"
        android:text="☆"
        android:textColor="#A64C3C"
        android:textSize="23sp" />
</LinearLayout>
